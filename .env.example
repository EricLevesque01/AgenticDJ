# ═══════════════════════════════════════════════════════
# EchoDJ — Environment Configuration
# ═══════════════════════════════════════════════════════
# Copy this file to .env and fill in your real values:
#   cp .env.example .env
#
# See docs/API_KEYS_SETUP.md for step-by-step instructions.

# ── Spotify (REQUIRED) ─────────────────────────────
# Get from: https://developer.spotify.com/dashboard
# Your app's Redirect URI must be: http://localhost:3000/callback
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret

# ── Last.fm (REQUIRED) ─────────────────────────────
# Get from: https://www.last.fm/api/account/create
LASTFM_API_KEY=your-lastfm-api-key

# ── LLM Provider (REQUIRED — pick one) ─────────────
# Options: gemini | ollama
ECHODJ_LLM_PROVIDER=gemini
ECHODJ_LLM_MODEL=gemini-2.0-flash

# Gemini (get from: https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key

# Ollama (local, no key needed — uncomment to use):
# ECHODJ_LLM_PROVIDER=ollama
# ECHODJ_LLM_MODEL=gemma3:4b
# OLLAMA_BASE_URL=http://localhost:11434

# ── ListenBrainz (OPTIONAL) ────────────────────────
# Enhances recommendations via collaborative filtering.
# Get from: https://listenbrainz.org/settings/
# If not set, Discoverer uses Last.fm + Spotify top tracks.
# LISTENBRAINZ_USER_TOKEN=your-listenbrainz-token

# ── TTS Voice ──────────────────────────────────────
# Options: en-US-GuyNeural (warm male) | en-US-AriaNeural (female)
ECHODJ_TTS_VOICE=en-US-GuyNeural

# ── Whisper (Speech-to-Text) ──────────────────────
# Requires NVIDIA GPU with CUDA. Set device=cpu if no GPU.
ECHODJ_WHISPER_MODEL=large-v3
ECHODJ_WHISPER_DEVICE=cuda
ECHODJ_WHISPER_COMPUTE_TYPE=int8

# ── MusicBrainz ────────────────────────────────────
# MusicBrainz API requires a contact email in the User-Agent header.
MUSICBRAINZ_CONTACT_EMAIL=your-email@example.com
